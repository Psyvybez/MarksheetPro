# ISBNdb API key — get a free key at https://isbndb.com/apidocs/v2
# Copy this file to .env and fill in your key.
# Note: for this app, the API key is also saved inside the app's Settings screen,
# so you only need this .env if you're pre-baking the key into a static deployment.
VITE_ISBNDB_API_KEY=your_key_here
